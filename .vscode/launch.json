    "version": "0.2.0",
    "configurations": [
        
        {
            "type": "node",
            "request": "launch",
            "name": "Backend",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal",
            "args":[ "${workspaceFolder}/src/index.ts"],
            "env": {
                "TS_NODE_PROJECT": "${workspaceFolder}/tsconfig.json"
            },
            "sourceMaps": true,
            "runtimeExecutable": "tsx", 
        }
    ]
}